# Nginx config for https://safeddara.tj/admin-mobile
# Add to your safeddara.tj server block in /etc/nginx/sites-available/

location = /admin-mobile {
    return 301 /admin-mobile/;
}
location /admin-mobile/ {
    alias /var/www/safeddara.mobile-admin/;
    try_files $uri $uri/ /admin-mobile/index.html;
}
